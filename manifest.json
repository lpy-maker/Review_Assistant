{
  "manifest_version": 3,
  "name": "审核意见助手",
  "version": "1.0.0",
  "description": "快速组合审核退回意见，提升审核效率",
  "minimum_chrome_version": "116",
  "permissions": [
    "sidePanel",
    "clipboardWrite"
  ],
  "action": {
    "default_title": "审核意见助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
